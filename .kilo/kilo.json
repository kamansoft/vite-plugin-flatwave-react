{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/lemys"]
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{GITHUB_PERSONAL_ACCESS_TOKEN}}"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "laravel-boost": {
      "type": "local",
      "command": ["php", "artisan", "boost:mcp"]
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "composer-trade": {
      "type": "local",
      "command": [
        "uvx",
        "composer-trade-mcp==0.1.4",
        "--hash",
        "sha256:37d8fcfd6ddc9c8155633f755159f3fcb1a63e7acc2a32513613341a851c84e2"
      ],
      "environment": {
        "COMPOSER_API_KEY": "{{COMPOSER_API_KEY}}",
        "COMPOSER_SECRET_KEY": "{{COMPOSER_SECRET_KEY}}"
      }
    }
  }
}
